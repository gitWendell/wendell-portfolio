# Copy this file to .env and fill in your real values
# Never commit .env to git!

# ── Server ────────────────────────────────────────────────
PORT=3000

# ── Keep-alive (Render free tier) ─────────────────────────
# Render spins a free service down after 15 min with no inbound traffic.
# The server pings its own public URL to keep itself awake.
#
# On Render this needs no config — RENDER_EXTERNAL_URL is injected for you,
# and the ping turns itself on. Locally it stays off (no URL to ping).
# Set KEEP_ALIVE=false to disable it even on Render.
KEEP_ALIVE=true
# Override the ping target if you're not on Render:
# KEEP_ALIVE_URL=https://your-app.onrender.com
# Must stay under 15 to beat the spin-down timer:
KEEP_ALIVE_MINUTES=14

# ── Access control ────────────────────────────────────────
# Master passcode. Unlocks the site on any visit (even without an invite
# link) and authorizes generating/listing invites (/token, /opens).
# Set this to a private value — anyone with it has full owner access.
OWNER_PASSCODE=your-owner-passcode-here

# ── AI provider: Ollama (primary) ─────────────────────────
# The server calls Ollama first. Set USE_OLLAMA=false to skip it
# and go straight to Gemini.
USE_OLLAMA=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── AI provider: Gemini (fallback) ────────────────────────
# Used automatically when Ollama is offline/unreachable.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Tried left to right. If a model is rate-limited (429 / quota exhausted),
# the server skips straight to the next one. Optional — this is the default.
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash

# ── AI provider: last resort (optional) ───────────────────
# Used only when every Gemini model above is rate-limited. Any
# OpenAI-compatible chat API works — set the base URL, key, and model:
#
#   Groq        https://api.groq.com/openai/v1        llama-3.3-70b-versatile
#   OpenRouter  https://openrouter.ai/api/v1          meta-llama/llama-3.3-70b-instruct:free
#   OpenAI      https://api.openai.com/v1             gpt-4o-mini
#
# Leave blank to disable — the chat then just errors when Gemini is capped.
FALLBACK_API_URL=
FALLBACK_API_KEY=
FALLBACK_MODEL=
